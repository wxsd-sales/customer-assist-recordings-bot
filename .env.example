# =============================================================================
# Webex Customer Assist Recordings -> Webex Space  -- Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Service-app credentials (admin REST APIs: list/details/metadata recordings,
# download audio bytes, look up people).
#
# RECOMMENDED scopes for the service app:
#   spark:recordings_read
#   spark:kms
#   spark:people_read
#   spark-admin:recordings_read
#   spark-admin:telephony_config_read
#   spark-compliance:recordings_read
#
# You have two choices for providing the service-app token:
#
#   Option A (recommended): supply OAuth refresh-token credentials below.
#   The service exchanges them for an access token at startup and rotates the
#   token automatically before it expires (so the bot never goes down because
#   of token expiry).
#
#   Option B: paste a static WEBEX_ACCESS_TOKEN. It works, but it will expire
#   (typically after 12 hours) and you'll have to restart with a fresh token.
#
# Provide EITHER Option A OR Option B (or both -- A is preferred when both
# are present, B is used as a fallback if a refresh attempt fails).
# -----------------------------------------------------------------------------

# --- Option A: OAuth refresh-token grant (preferred) -------------------------
WEBEX_CLIENT_ID=
WEBEX_CLIENT_SECRET=
WEBEX_REFRESH_TOKEN=

# --- Option B: static access token (fallback / quick start) ------------------
WEBEX_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Bot credentials (post messages, listen for @mentions and card submissions
# over the Webex Mercury WebSocket).
# -----------------------------------------------------------------------------
WEBEX_BOT_TOKEN=your_bot_token_here

# -----------------------------------------------------------------------------
# The Webex space (room) the bot will post into. Mentions in any other space
# or DM are silently ignored.
# -----------------------------------------------------------------------------
WEBEX_ROOM_ID=your_room_id_here

# -----------------------------------------------------------------------------
# Optional: shared secret for the (optional) /webhook/converged-recording
# endpoint. If set, incoming webhook requests are HMAC-SHA1 verified.
# -----------------------------------------------------------------------------
WEBEX_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Local backup of every recording (so files survive after the temporary
# Webex download URL expires). Set to "" (empty) to disable disk storage.
# -----------------------------------------------------------------------------
RECORDING_STORAGE_DIR=./recordings

# Hard cap on attachment size (bytes). Webex caps message attachments at ~100MB;
# default leaves headroom. Larger recordings fall back to posting the temp link.
# MAX_UPLOAD_BYTES=99614720

# -----------------------------------------------------------------------------
# Optional tuning
# -----------------------------------------------------------------------------
# PORT=3000
# POLL_INTERVAL_SECONDS=10
# LINK_READY_MAX_RETRIES=20
# LINK_READY_RETRY_SECONDS=10
